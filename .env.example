# Firebase Configuration for privacyIDEA Authenticator - EXAMPLE FILE
# Copy this file to .env and fill in your actual Firebase credentials
# DO NOT commit the .env file - it contains sensitive information

# Firebase Project Configuration (shared across platforms)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Firebase Android Configuration
FIREBASE_ANDROID_API_KEY=your-android-api-key
FIREBASE_ANDROID_APP_ID=your-android-app-id

# Firebase iOS Configuration
FIREBASE_IOS_API_KEY=your-ios-api-key
FIREBASE_IOS_APP_ID=your-ios-app-id
FIREBASE_IOS_CLIENT_ID=your-ios-client-id
FIREBASE_IOS_BUNDLE_ID=privacyidea.authenticator

# Firebase Web Configuration
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_WEB_APP_ID=your-web-app-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# privacyIDEA Server Configuration
PRIVACYIDEA_URL=http://10.0.2.2:8080

# Instructions:
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Add Android, iOS, and Web apps to your project
# 3. Copy the configuration values from each app into this file
# 4. Rename this file to .env
# 5. For Flutter builds, pass these variables using --dart-define-from-file=.env