# Flutter Web Test Build
# Builds Flutter web app for E2E testing with Playwright
#
# Usage:
#   docker build -t marty-wallet-test -f docker/Dockerfile.flutter.web.test .
#   docker run -p 9081:80 marty-wallet-test

# Build stage
FROM ghcr.io/cirruslabs/flutter:stable AS builder

WORKDIR /app

# Copy dependency files first for caching
COPY pubspec.yaml pubspec.lock ./

# Copy local path dependencies before pub get
COPY local_wasm_overrides/ ./local_wasm_overrides/
COPY local_plugins/ ./local_plugins/

# Get dependencies
RUN flutter pub get

# Copy source code
COPY . .

# Build web with test entry point
RUN flutter build web \
    --target=lib/mains/main_web_test.dart \
    --release \
    --dart-define=MARTY_API_URL=http://localhost:8000 \
    --dart-define=TEST_MODE=true

# Production stage with nginx
FROM nginx:alpine

# Copy built web app
COPY --from=builder /app/build/web /usr/share/nginx/html

# Copy WASM files for marty_rs (crypto library)
# These need to be at the path the Flutter app expects: /assets/packages/marty_rs/
COPY --from=builder /app/local_wasm_overrides/marty_rs /usr/share/nginx/html/assets/packages/marty_rs

# Custom nginx config for SPA routing
RUN cat > /etc/nginx/conf.d/default.conf << 'EOF'
server {
    listen 80;
    server_name localhost;
    root /usr/share/nginx/html;
    index index.html;

    # Enable CORS for test environment
    add_header 'Access-Control-Allow-Origin' '*' always;
    add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
    add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization' always;

    # Allow embedding in iframe for Playwright tests
    add_header 'X-Frame-Options' 'ALLOWALL' always;
    add_header 'Content-Security-Policy' "frame-ancestors *;" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Health check endpoint
    location /health {
        return 200 'OK';
        add_header Content-Type text/plain;
    }

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1d;
        add_header Cache-Control "public, immutable";
    }
}
EOF

EXPOSE 80

# Health check using the /health endpoint (use 127.0.0.1 for IPv6 compatibility)
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:80/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
